{
  "version": "1.0.0",
  "default_schedule": "balanced_cb",
  "mixture_classes": {
    "fujitsu_b4/tool_flip": {
      "name": "Fujitsu Tool-Flip Harmful",
      "category": "harmful",
      "description": "Fujitsu attack-success traces used for rerouting.",
      "source_datasets": ["fujitsu_b4"],
      "default_lmp": "cb_full_sequence"
    },
    "fujitsu_b4/benign": {
      "name": "Fujitsu Benign",
      "category": "benign",
      "description": "Fujitsu benign/retain traces.",
      "source_datasets": ["fujitsu_b4"],
      "default_lmp": "assistant_and_tool"
    },
    "agentdojo/harmful": {
      "name": "AgentDojo Harmful",
      "category": "harmful",
      "description": "AgentDojo attack-success traces.",
      "source_datasets": ["agentdojo"],
      "default_lmp": "cb_full_sequence"
    },
    "agentdojo/resisted": {
      "name": "AgentDojo Resisted",
      "category": "benign",
      "description": "AgentDojo attack-present but resisted traces (retain).",
      "source_datasets": ["agentdojo"],
      "default_lmp": "assistant_and_tool"
    },
    "agentdojo/benign": {
      "name": "AgentDojo Benign",
      "category": "benign",
      "description": "AgentDojo benign traces.",
      "source_datasets": ["agentdojo"],
      "default_lmp": "assistant_and_tool"
    }
  },
  "schedules": {
    "balanced_cb": {
      "name": "Balanced CB",
      "description": "Uniform sample weights across harmful and benign classes.",
      "class_weights": {
        "fujitsu_b4/tool_flip": 1.0,
        "fujitsu_b4/benign": 1.0,
        "agentdojo/harmful": 1.0,
        "agentdojo/resisted": 1.0,
        "agentdojo/benign": 1.0
      },
      "sampling_strategy": "proportional"
    },
    "attack_focus": {
      "name": "Attack Focus",
      "description": "Increase weight on harmful traces to prioritize blocking attacks.",
      "class_weights": {
        "fujitsu_b4/tool_flip": 2.0,
        "fujitsu_b4/benign": 0.8,
        "agentdojo/harmful": 2.0,
        "agentdojo/resisted": 0.8,
        "agentdojo/benign": 0.8
      },
      "sampling_strategy": "proportional"
    },
    "capability_focus": {
      "name": "Capability Focus",
      "description": "Increase retain-class weight to preserve baseline tool behavior.",
      "class_weights": {
        "fujitsu_b4/tool_flip": 0.8,
        "fujitsu_b4/benign": 1.8,
        "agentdojo/harmful": 0.8,
        "agentdojo/resisted": 1.8,
        "agentdojo/benign": 1.8
      },
      "sampling_strategy": "proportional"
    },
    "staged_introduction": {
      "name": "Staged Introduction",
      "description": "Start with capability-heavy weighting, then move toward harmful focus.",
      "class_weights": {
        "fujitsu_b4/tool_flip": 1.0,
        "fujitsu_b4/benign": 1.0,
        "agentdojo/harmful": 1.0,
        "agentdojo/resisted": 1.0,
        "agentdojo/benign": 1.0
      },
      "sampling_strategy": "proportional",
      "curriculum": {
        "type": "step",
        "interpolation": "none",
        "phases": [
          {
            "name": "warmup_capability",
            "start_step": 0,
            "end_step": 100,
            "class_weights": {
              "fujitsu_b4/tool_flip": 0.7,
              "fujitsu_b4/benign": 1.6,
              "agentdojo/harmful": 0.7,
              "agentdojo/resisted": 1.6,
              "agentdojo/benign": 1.6
            },
            "lmp_overrides": {
              "fujitsu_b4/tool_flip": "assistant_and_tool",
              "agentdojo/harmful": "assistant_and_tool"
            }
          },
          {
            "name": "balance",
            "start_step": 100,
            "end_step": 220,
            "class_weights": {
              "fujitsu_b4/tool_flip": 1.0,
              "fujitsu_b4/benign": 1.0,
              "agentdojo/harmful": 1.0,
              "agentdojo/resisted": 1.0,
              "agentdojo/benign": 1.0
            },
            "lmp_overrides": {
              "fujitsu_b4/tool_flip": "cb_full_sequence",
              "agentdojo/harmful": "cb_full_sequence"
            }
          },
          {
            "name": "attack_hardening",
            "start_step": 220,
            "end_step": 400,
            "class_weights": {
              "fujitsu_b4/tool_flip": 1.8,
              "fujitsu_b4/benign": 0.9,
              "agentdojo/harmful": 1.8,
              "agentdojo/resisted": 0.9,
              "agentdojo/benign": 0.9
            },
            "lmp_overrides": {
              "fujitsu_b4/tool_flip": "action_commitment",
              "agentdojo/harmful": "action_commitment"
            }
          }
        ]
      }
    }
  }
}
